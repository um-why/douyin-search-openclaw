{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "抖音抖人作品获取 - 命令行入参",
    "description": "抖音实时获取博主作品, 命令行参数入参Schema详解",
    "required": [
        "url"
    ],
    "properties": {
        "url": {
            "type": "string",
            "description": "抖音博主主页URL 或 抖音博主SEC_UID"
        },
        "limit": {
            "type": "number",
            "description": "获取作品数量",
            "minimum": 1,
            "maximum": 100000,
            "default": 10
        }
    },
    "additionalProperties": false
}